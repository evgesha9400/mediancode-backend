{
  "name": "UserManagementApi",
  "version": "1.0.0",
  "author": "Median Code",
  "description": "Complete API example exercising all input model fields",
  "tags": [
    {
      "name": "Users",
      "description": "User management operations"
    },
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    }
  ],
  "objects": [
    {
      "name": "User",
      "description": "Represents a user in the system",
      "fields": [
        {
          "type": "int",
          "name": "id",
          "required": true,
          "description": "Unique user identifier"
        },
        {
          "type": "str",
          "name": "email",
          "required": true,
          "description": "User email address",
          "validators": [
            { "name": "max_length", "params": { "value": 255 } }
          ]
        },
        {
          "type": "str",
          "name": "name",
          "required": true,
          "description": "User display name",
          "validators": [
            { "name": "min_length", "params": { "value": 1 } },
            { "name": "max_length", "params": { "value": 100 } }
          ]
        },
        {
          "type": "int",
          "name": "age",
          "required": false,
          "description": "User age in years",
          "validators": [
            { "name": "ge", "params": { "value": 0 } },
            { "name": "le", "params": { "value": 150 } }
          ]
        },
        {
          "type": "bool",
          "name": "is_active",
          "required": false,
          "description": "Whether the user account is active",
          "default_value": "True"
        },
        {
          "type": "datetime.datetime",
          "name": "created_at",
          "required": true,
          "description": "Account creation timestamp"
        }
      ]
    },
    {
      "name": "UserList",
      "description": "Paginated list of users",
      "fields": [
        {
          "type": "List[User]",
          "name": "items",
          "required": true,
          "description": "List of user objects"
        },
        {
          "type": "int",
          "name": "total",
          "required": true,
          "description": "Total number of users"
        }
      ]
    },
    {
      "name": "CreateUserRequest",
      "description": "Request body for creating a new user",
      "fields": [
        {
          "type": "str",
          "name": "email",
          "required": true,
          "description": "User email address"
        },
        {
          "type": "str",
          "name": "name",
          "required": true,
          "description": "User display name"
        },
        {
          "type": "str",
          "name": "password",
          "required": true,
          "description": "User password",
          "validators": [
            { "name": "min_length", "params": { "value": 8 } }
          ]
        }
      ]
    },
    {
      "name": "UpdateUserRequest",
      "description": "Request body for updating user details",
      "fields": [
        {
          "type": "str",
          "name": "name",
          "required": false,
          "description": "New display name"
        },
        {
          "type": "int",
          "name": "age",
          "required": false,
          "description": "New age value"
        }
      ]
    },
    {
      "name": "LoginRequest",
      "description": "Login credentials",
      "fields": [
        {
          "type": "str",
          "name": "email",
          "required": true
        },
        {
          "type": "str",
          "name": "password",
          "required": true
        }
      ]
    },
    {
      "name": "TokenResponse",
      "description": "Authentication token response",
      "fields": [
        {
          "type": "str",
          "name": "access_token",
          "required": true,
          "description": "JWT access token"
        },
        {
          "type": "str",
          "name": "token_type",
          "required": true,
          "description": "Token type (bearer)",
          "default_value": "'bearer'"
        }
      ]
    }
  ],
  "views": [
    {
      "name": "ListUsers",
      "path": "/users",
      "method": "GET",
      "tag": "Users",
      "description": "List all users with pagination",
      "response": "UserList",
      "response_shape": "object",
      "use_envelope": true,
      "query_params": [
        {
          "name": "limit",
          "type": "int",
          "required": false,
          "description": "Maximum number of results"
        },
        {
          "name": "offset",
          "type": "int",
          "required": false,
          "description": "Number of results to skip"
        }
      ]
    },
    {
      "name": "GetUser",
      "path": "/users/{user_id}",
      "method": "GET",
      "tag": "Users",
      "description": "Get a specific user by ID",
      "response": "User",
      "response_shape": "object",
      "use_envelope": true,
      "path_params": [
        {
          "name": "user_id",
          "type": "int",
          "description": "The user's unique identifier"
        }
      ]
    },
    {
      "name": "CreateUser",
      "path": "/users",
      "method": "POST",
      "tag": "Users",
      "description": "Create a new user account",
      "response": "User",
      "request": "CreateUserRequest",
      "response_shape": "object",
      "use_envelope": true
    },
    {
      "name": "UpdateUser",
      "path": "/users/{user_id}",
      "method": "PUT",
      "tag": "Users",
      "description": "Update an existing user",
      "response": "User",
      "request": "UpdateUserRequest",
      "response_shape": "object",
      "use_envelope": true,
      "path_params": [
        {
          "name": "user_id",
          "type": "int",
          "description": "The user's unique identifier"
        }
      ]
    },
    {
      "name": "DeleteUser",
      "path": "/users/{user_id}",
      "method": "DELETE",
      "tag": "Users",
      "description": "Delete a user account",
      "response": "User",
      "response_shape": "object",
      "use_envelope": false,
      "path_params": [
        {
          "name": "user_id",
          "type": "int",
          "description": "The user's unique identifier"
        }
      ]
    },
    {
      "name": "Login",
      "path": "/auth/login",
      "method": "POST",
      "tag": "Auth",
      "description": "Authenticate and receive access token",
      "response": "TokenResponse",
      "request": "LoginRequest",
      "response_shape": "object",
      "use_envelope": false
    }
  ],
  "config": {
    "healthcheck": "/health",
    "response_placeholders": true
  }
}
