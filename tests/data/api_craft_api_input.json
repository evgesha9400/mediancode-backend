{
  "name": "ApiCraftApi",
  "version": "0.1.0",
  "author": "Median Code Generator",
  "description": "API Generator Service - Generate FastAPI applications from JSON specifications",
  "objects": [
    {
      "name": "InputField",
      "fields": [
        { "type": "str", "name": "type", "required": true },
        { "type": "str", "name": "name", "required": true },
        { "type": "bool", "name": "required", "required": false }
      ]
    },
    {
      "name": "InputModel",
      "fields": [
        { "type": "str", "name": "name", "required": true },
        { "type": "List[$InputField]", "name": "fields", "required": true }
      ]
    },
    {
      "name": "InputQueryParam",
      "fields": [
        { "type": "str", "name": "name", "required": true },
        { "type": "str", "name": "type", "required": true },
        { "type": "bool", "name": "required", "required": false }
      ]
    },
    {
      "name": "InputPathParam",
      "fields": [
        { "type": "str", "name": "name", "required": true },
        { "type": "str", "name": "type", "required": true }
      ]
    },
    {
      "name": "InputView",
      "fields": [
        { "type": "str", "name": "name", "required": true },
        { "type": "str", "name": "path", "required": true },
        { "type": "str", "name": "method", "required": true },
        { "type": "str", "name": "tag", "required": false },
        { "type": "str", "name": "response", "required": false },
        { "type": "str", "name": "request", "required": false },
        { "type": "List[$InputQueryParam]", "name": "query_params", "required": false },
        { "type": "List[$InputPathParam]", "name": "path_params", "required": false }
      ]
    },
    {
      "name": "InputApiConfig",
      "fields": [
        { "type": "str", "name": "healthcheck", "required": false },
        { "type": "bool", "name": "response_placeholders", "required": true }
      ]
    },
    {
      "name": "GenerateApiRequest",
      "fields": [
        { "type": "str", "name": "name", "required": true },
        { "type": "str", "name": "version", "required": false },
        { "type": "str", "name": "author", "required": false },
        { "type": "str", "name": "description", "required": false },
        { "type": "List[$InputModel]", "name": "objects", "required": true },
        { "type": "List[$InputView]", "name": "views", "required": true },
        { "type": "$InputApiConfig", "name": "config", "required": false }
      ]
    },
    {
      "name": "GenerateApiResponse",
      "fields": [
        { "type": "str", "name": "message", "required": true },
        { "type": "str", "name": "project_name", "required": true },
        { "type": "List[str]", "name": "generated_files", "required": true }
      ]
    },
    {
      "name": "GenerateApiResponse",
      "fields": [
        { "type": "str", "name": "message", "required": true },
        { "type": "str", "name": "project_name", "required": true },
        { "type": "List[str]", "name": "generated_files", "required": true }
      ]
    }
  ],
  "views": [
    {
      "name": "GenerateApi",
      "path": "/generate",
      "method": "POST",
      "tag": "Generation",
      "response": "$GenerateApiResponse",
      "request": "$GenerateApiRequest"
    }
  ],
  "config": {
    "healthcheck": "/healthcheck",
    "response_placeholders": true
  }
}
