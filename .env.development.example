# Development Environment Configuration
# Copy to .env.development and fill in your values
#
# Backend URL: https://api.dev.mediancode.com
# Frontend URL: https://dev.mediancode.com

# Database - Railway auto-sets this, do NOT add here
# DATABASE_URL is automatically injected by Railway

# =============================================================================
# Clerk Authentication (https://dashboard.clerk.com → API Keys)
# =============================================================================
# Use your DEVELOPMENT Clerk application (separate from production)
# Copy "Frontend API URL" from the right sidebar
CLERK_FRONTEND_API_URL=https://your-dev-clerk-app.clerk.accounts.dev

# Optional: JWT audience claim validation (leave empty if not using)
CLERK_JWT_AUDIENCE=

# =============================================================================
# Application Settings
# =============================================================================
GLOBAL_NAMESPACE_ID=namespace-global

# CORS - Development frontend URL
FRONTEND_URL=https://dev.mediancode.com
