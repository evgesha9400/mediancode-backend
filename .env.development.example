# Development Environment Configuration
# Copy to .env.development and fill in your values

# Database (Railway auto-sets this, but you can override for local dev)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/median_code_dev

# Clerk Authentication (use your dev Clerk instance if you have one)
CLERK_ISSUER_URL=https://your-dev-clerk.clerk.accounts.dev
CLERK_AUDIENCE=

# Application Settings
GLOBAL_NAMESPACE_ID=namespace-global

# CORS - Your Vercel preview/dev URL
FRONTEND_URL=http://localhost:5173
