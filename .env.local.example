# Local Development Configuration
# Copy to .env.local and fill in your values

# Database - matches docker-compose.yml
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/median_code

# Clerk Authentication
# Use your Clerk dev instance or the same as development
CLERK_ISSUER_URL=https://your-clerk.clerk.accounts.dev
CLERK_AUDIENCE=

# Application Settings
GLOBAL_NAMESPACE_ID=namespace-global

# CORS - Local frontend
FRONTEND_URL=http://localhost:5173
