# Local Development Configuration
# Copy to .env.local and fill in your values

# Database - matches docker-compose.yml
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/median_code

# =============================================================================
# Clerk Authentication (https://dashboard.clerk.com → API Keys)
# =============================================================================
# Copy "Frontend API URL" from the right sidebar (e.g., https://clerk.mediancode.com)
CLERK_FRONTEND_API_URL=https://clerk.yourapp.com

# Optional: JWT audience claim validation (leave empty if not using)
CLERK_JWT_AUDIENCE=

# =============================================================================
# Application Settings
# =============================================================================
GLOBAL_NAMESPACE_ID=namespace-global

# CORS - Your local frontend URL
FRONTEND_URL=http://localhost:5173
