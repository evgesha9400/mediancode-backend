{#- Parameters: -#}
{#- api : TemplateApi -#}
[tool.poetry]
name = "{{ api.spaced_name }}"
version = "{{ api.version }}"
description = "{{ api.description }}"
authors = ["{{ api.author }}"]
readme = "README.md"


[tool.poetry.dependencies]
python = "^3.13"
fastapi = "^0.115.4"
uvicorn = "^0.32.0"


[tool.poetry.group.dev.dependencies]
pyyaml = "^6.0.2"
httpx = "^0.27.2"

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"
