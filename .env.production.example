# Production Environment Configuration
# Copy to .env.production and fill in your values
#
# Backend URL: https://api.mediancode.com
# Frontend URL: https://mediancode.com

# Database - Set via Coolify environment variables (Postgres internal URL)
# The postgres:// scheme is auto-converted to postgresql+asyncpg:// by settings.py

# =============================================================================
# Clerk Authentication (https://dashboard.clerk.com → API Keys)
# =============================================================================
# Use your PRODUCTION Clerk application (separate from development)
# Copy "Frontend API URL" from the right sidebar
CLERK_FRONTEND_API_URL=https://your-prod-clerk-app.clerk.accounts.dev

# Copy "Secret keys" from the API Keys page (e.g., sk_live_...)
CLERK_SECRET_KEY=

# Optional: JWT audience claim validation (leave empty if not using)
CLERK_JWT_AUDIENCE=

# =============================================================================
# Application Settings
# =============================================================================
SYSTEM_NAMESPACE_ID=00000000-0000-0000-0000-000000000001

# CORS - Production frontend URL
FRONTEND_URL=https://mediancode.com

# Environment - Set to "development" or "production" in Coolify
# Controls API docs visibility (disabled when set to "production")
ENVIRONMENT=production
