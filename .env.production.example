# Production Environment Configuration
# Copy to .env.production and fill in your values

# Database (Railway auto-sets this - do NOT override)
# DATABASE_URL is automatically injected by Railway

# Clerk Authentication (production Clerk instance)
CLERK_ISSUER_URL=https://your-prod-clerk.clerk.accounts.dev
CLERK_AUDIENCE=

# Application Settings
GLOBAL_NAMESPACE_ID=namespace-global

# CORS - Your production Vercel URL
FRONTEND_URL=https://app.mediancode.com
